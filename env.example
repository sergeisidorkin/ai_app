# === Общие для всех сред ===
DJANGO_SETTINGS_MODULE=settings
# Переключатель пакета settings/: local|prod
DJANGO_ENV=prod

# === Продакшн ===
DEBUG=False
SECRET_KEY=__set_in_env__
ALLOWED_HOSTS=imcmontanai.ru
CSRF_TRUSTED_ORIGINS=https://imcmontanai.ru
DATABASE_URL=postgres://user:pass@dbhost:5432/ai_app
STATIC_ROOT=/var/www/ai_app/static

# MS Graph / Azure AD (прод)
MS_CLIENT_ID=__set_in_env__
MS_CLIENT_SECRET=__set_in_env__
MS_TENANT_ID=common
MS_REDIRECT_URI=https://imcmontanai.ru/onedrive/callback

# OpenAI (прод)
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=__set_in_env__

# SMTP app (шифрование сохранённых внешних SMTP-секретов)
SMTP_APP_ENCRYPTION_KEY=__set_in_env__

# Moodle / Learning
MOODLE_BASE_URL=https://learn.imcmontanai.ru
MOODLE_LAUNCH_PATH=/
MOODLE_USER_AUTH_PLUGIN=manual
MOODLE_SSO_LAUNCH_MODE=oidc
MOODLE_OIDC_LOGIN_PATH=/auth/oidc/
MOODLE_OIDC_LOGIN_SOURCE=django
MOODLE_OIDC_PROMPT_LOGIN=False
MOODLE_WEB_SERVICE_TOKEN=__set_in_env__
MOODLE_WEB_SERVICE_TIMEOUT=20

# Django as OIDC Provider for Moodle SSO
OIDC_ISSUER_URL=https://imcmontanai.ru/o
OIDC_RSA_PRIVATE_KEY_FILE=/absolute/path/to/oidc.key
MOODLE_OIDC_CLIENT_ID=__set_after_moodle_client_creation__
OIDC_STAFF_ONLY_CLIENT_IDS=__same_client_id_or_comma_separated_list__

# === Dev (локально) — включай READ_DOTENV=True в settings/local.py ===
# DEBUG=True
# ALLOWED_HOSTS=127.0.0.1,localhost
# DATABASE_URL=postgres://ai_app:pass@localhost:5432/ai_app
# MS_REDIRECT_URI=http://localhost:8000/onedrive/callback