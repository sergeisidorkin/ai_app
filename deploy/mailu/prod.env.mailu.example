# Django mail settings for the app host after switching to Mailu.
# Copy these values into $HOME/ai_appdir/env/prod.env on the server.

# Preferred compact form.
EMAIL_URL=smtp+tls://notifications%40imcmontanai.ru:replace-me@127.0.0.1:587

# Django keeps using this as the sender address unless overridden per message.
DEFAULT_FROM_EMAIL=notifications@imcmontanai.ru
EMAIL_TIMEOUT=10

# Explicit form if you do not want EMAIL_URL.
# EMAIL_HOST=127.0.0.1
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=notifications@imcmontanai.ru
# EMAIL_HOST_PASSWORD=replace-me
