# Mailu root data directory on the server.
ROOT=/opt/mailu

# Use a stable Mailu release tag.
MAILU_VERSION=2024.06

# Generate a strong random value before first start.
SECRET_KEY=replace-with-16-byte-random-secret

# Set this to the host public IPv4 address if possible.
# 0.0.0.0 also works for single-host setups, but a fixed public IP is preferred.
BIND_ADDRESS4=0.0.0.0

# Internal Mailu subnet. Change only if it conflicts with another Docker network.
SUBNET=192.168.203.0/24

# Main mail domain and public mail hostname.
DOMAIN=imcmontanai.ru
HOSTNAMES=mail.imcmontanai.ru
POSTMASTER=postmaster

# The host already has its own reverse proxy on 80/443, so Mailu uses manual certs.
TLS_FLAVOR=cert
TLS_CERT_FILENAME=cert.pem
TLS_KEYPAIR_FILENAME=key.pem

# Keep the admin UI and a familiar webmail client enabled.
ADMIN=true
WEBMAIL=roundcube
WEBDAV=none

# Timezone and branding.
TZ=Etc/UTC
SITENAME=IMC Montan Mail
WEBSITE=https://imcmontanai.ru
WEB_ADMIN=/admin
WEB_WEBMAIL=/webmail
WEBROOT_REDIRECT=/admin

# Security and auth defaults.
AUTH_RATELIMIT_IP=5/hour
AUTH_RATELIMIT_USER=50/day
SESSION_COOKIE_SECURE=True
REAL_IP_HEADER=X-Forwarded-For
# Replace with the CIDR that Mailu sees for your reverse proxy connection.
# On single-host Docker setups this is often a bridge network address, not 127.0.0.1.
REAL_IP_FROM=replace-with-reverse-proxy-cidr

# Enable the internal HTTP port for the existing reverse proxy.
PORTS=25,80,143,465,587,993,4190

# Mail flow defaults.
MESSAGE_SIZE_LIMIT=25000000
MESSAGE_RATELIMIT=300/day
DEFAULT_SPAM_THRESHOLD=80
DMARC_RUA=postmaster
DMARC_RUF=postmaster
WELCOME=false

# Create the initial admin account automatically on first boot.
INITIAL_ADMIN_ACCOUNT=admin
INITIAL_ADMIN_DOMAIN=imcmontanai.ru
INITIAL_ADMIN_PW=replace-with-strong-admin-password
INITIAL_ADMIN_MODE=ifmissing

# Optional future API integration.
API_TOKEN=replace-with-mailu-api-token

# Optional: exempt the notification account from message rate limits.
# MESSAGE_RATELIMIT_EXEMPTION=notifications@imcmontanai.ru

# Optional: if the proxy terminates TLS and serves Mailu over HTTP only,
# leave secure cookies enabled because the external URL is still HTTPS.
