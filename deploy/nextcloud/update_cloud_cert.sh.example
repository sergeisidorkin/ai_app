#!/usr/bin/env bash
set -euo pipefail

CERT_ID="replace-with-yandex-certificate-id"
YC_BIN="/home/sergei/yandex-cloud/bin/yc"
CHAIN_TMP="$(mktemp)"
KEY_TMP="$(mktemp)"
TARGET_DIR="/etc/nginx/ssl-cloud"

cleanup() {
  rm -f "$CHAIN_TMP" "$KEY_TMP"
}
trap cleanup EXIT

"$YC_BIN" certificate-manager certificate content \
  --id "$CERT_ID" \
  --chain "$CHAIN_TMP" \
  --key "$KEY_TMP"

if [ -f "$TARGET_DIR/fullchain.pem" ] && [ -f "$TARGET_DIR/privkey.pem" ]; then
  if cmp -s "$CHAIN_TMP" "$TARGET_DIR/fullchain.pem" && cmp -s "$KEY_TMP" "$TARGET_DIR/privkey.pem"; then
    echo "$(date -Iseconds) Cloud certificate unchanged, nothing to do."
    exit 0
  fi
fi

install -m 640 -o root -g root "$CHAIN_TMP" "$TARGET_DIR/fullchain.pem"
install -m 640 -o root -g root "$KEY_TMP"   "$TARGET_DIR/privkey.pem"

nginx -t
systemctl reload nginx

echo "$(date -Iseconds) Cloud certificate updated and nginx reloaded."
