# Django learning settings for the app host after Moodle is published.
# Copy these values into $HOME/ai_appdir/env/prod.env on the server.

MOODLE_BASE_URL=https://learn.imcmontanai.ru
MOODLE_LAUNCH_PATH=/

# Optional explicit endpoint. If omitted, Django uses:
# ${MOODLE_BASE_URL}/webservice/rest/server.php
# MOODLE_WEB_SERVICE_URL=https://learn.imcmontanai.ru/webservice/rest/server.php

MOODLE_WEB_SERVICE_TOKEN=replace-me
MOODLE_WEB_SERVICE_TIMEOUT=20
