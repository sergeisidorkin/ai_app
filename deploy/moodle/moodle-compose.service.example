[Unit]
Description=Moodle Docker Compose Stack
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/moodle
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
Environment=APP_ROOT=/home/sergei/ai_appdir/ai_app
Environment=WAIT_TIMEOUT_SECONDS=300
ExecStart=/usr/bin/docker compose --env-file /opt/moodle/moodle.env up -d
ExecStartPost=/usr/bin/env bash /opt/moodle/moodle-healthcheck.sh
ExecStop=/usr/bin/docker compose --env-file /opt/moodle/moodle.env stop
ExecReload=/usr/bin/docker compose --env-file /opt/moodle/moodle.env up -d
ExecReload=/usr/bin/env bash /opt/moodle/moodle-healthcheck.sh
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
