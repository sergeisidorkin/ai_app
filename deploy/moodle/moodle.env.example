ROOT=/opt/moodle
# Bind-mounted Moodle local plugins live under ${ROOT}/local/.
# Install auth_oidc through the image's plugin layer. Keep the JSON on one line.
MOODLE_PLUGINS_JSON=[{"giturl":"https://github.com/microsoft/moodle-auth_oidc.git","branch":"MOODLE_405_STABLE","installpath":"auth/oidc"}]

MOODLE_HOST=learn.imcmontanai.ru
MOODLE_LOCAL_PORT=8090
MOODLE_SITE_FULLNAME=IMC Montan Learning
MOODLE_SITE_SHORTNAME=IMC Learning

MOODLE_ADMIN_USERNAME=admin
MOODLE_ADMIN_PASSWORD=replace-me
MOODLE_ADMIN_EMAIL=admin@imcmontanai.ru
MOODLE_SUPPORT_EMAIL=admin@imcmontanai.ru
MOODLE_NOREPLY_EMAIL=noreply@imcmontanai.ru

MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle
MOODLE_DB_PASSWORD=replace-me
